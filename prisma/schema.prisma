datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
  MODERATOR
}

enum ReviewStatus {
  PENDING
  APPROVED
  HIDDEN
}

enum LogoType {
  PARTNER
  ARTIST
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  YOUTUBE
  LINKEDIN
  WHATSAPP
}

enum Palette {
  RED_BLACK
  COBALT_GOLD
}

enum VideoSourceType {
  UPLOAD
  YOUTUBE
  VIMEO
  EXTERNAL
}

enum TrainingLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum UserTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(EDITOR)
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model Session {
  id          String    @id @default(cuid())
  token       String    @unique
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  adminUserId String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

model Category {
  id        String  @id @default(cuid())
  slug      String  @unique
  order     Int     @default(0)
  visualOnly Boolean @default(false)
  titleFr   String
  titleEn   String
  itemsFr   String  @default("")
  itemsEn   String  @default("")
  colorFrom String  @default("#dc2626")
  colorTo   String  @default("#111111")
  imagePath String?
}

model PortfolioTab {
  id      String @id @default(cuid())
  slug    String @unique
  labelFr String
  labelEn String
  order   Int    @default(0)
}

model Project {
  id            String   @id @default(cuid())
  slug          String   @unique
  titleFr       String
  titleEn       String
  category      String
  colorFrom     String   @default("#dc2626")
  colorTo       String   @default("#111111")
  youtubeUrl    String?
  videoFilePath String?
  contextFr     String   @default("")
  contextEn     String   @default("")
  objectivesFr  String   @default("")
  objectivesEn  String   @default("")
  location      String   @default("")
  projectDate   String   @default("")
  order         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Testimonial {
  id          String   @id @default(cuid())
  clientName  String
  clientRole  String   @default("")
  companyName String   @default("")
  colorHex    String   @default("#dc2626")
  quoteFr     String
  quoteEn     String
  rating      Int      @default(5)
  verified    Boolean  @default(true)
  order       Int      @default(0)
}

model Review {
  id          String       @id @default(cuid())
  authorName  String
  authorEmail String
  rating      Int          @default(5)
  comment     String
  status      ReviewStatus @default(PENDING)
  ipAddress   String       @default("")
  createdAt   DateTime     @default(now())
}

model BannedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String   @default("")
  createdAt DateTime @default(now())
}

model FaqItem {
  id         String @id @default(cuid())
  questionFr String
  questionEn String
  answerFr   String
  answerEn   String
  order      Int    @default(0)
}

model PartnerLogo {
  id            String   @id @default(cuid())
  name          String
  type          LogoType @default(PARTNER)
  colorHex      String   @default("#dc2626")
  logoImagePath String?
  order         Int      @default(0)
}

model SocialLink {
  id       String         @id @default(cuid())
  platform SocialPlatform @unique
  url      String         @default("")
  visible  Boolean        @default(true)
}

model ContactMessage {
  id             String   @id @default(cuid())
  name           String
  company        String   @default("")
  email          String
  phone          String   @default("")
  budget         String   @default("")
  subject        String
  message        String
  attachmentPath String?
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model WhyChooseUsItem {
  id      String @id @default(cuid())
  iconKey String @default("sparkles")
  titleFr String
  titleEn String
  textFr  String
  textEn  String
  order   Int    @default(0)
}

model CommitmentItem {
  id      String @id @default(cuid())
  iconKey String @default("sparkles")
  titleFr String
  titleEn String
  textFr  String
  textEn  String
  order   Int    @default(0)
}

model TeamMember {
  id        String  @id @default(cuid())
  name      String
  roleFr    String  @default("")
  roleEn    String  @default("")
  photoPath String?
  rating    Int     @default(5)
  order     Int     @default(0)
}

model TrainingCategory {
  id        String     @id @default(cuid())
  slug      String     @unique
  nameFr    String
  nameEn    String
  order     Int        @default(0)
  trainings Training[]
}

model Training {
  id              String             @id @default(cuid())
  slug            String             @unique
  category        TrainingCategory   @relation(fields: [categoryId], references: [id])
  categoryId      String
  titleFr         String
  titleEn         String
  shortDescFr     String             @default("")
  shortDescEn     String             @default("")
  presentationFr  String             @default("")
  presentationEn  String             @default("")
  objectivesFr    String             @default("")
  objectivesEn    String             @default("")
  level           TrainingLevel      @default(BEGINNER)
  durationMinutes Int                @default(0)
  thumbnailPath   String?
  viewCount       Int                @default(0)
  order           Int                @default(0)
  published       Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  lessons         TrainingLesson[]
  resources       TrainingResource[]
  faqItems        TrainingFaqItem[]
  comments        TrainingComment[]
  lessonProgress  LessonProgress[]
  certificates    Certificate[]
}

model TrainingLesson {
  id              String          @id @default(cuid())
  training        Training        @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  trainingId      String
  titleFr         String
  titleEn         String
  order           Int             @default(0)
  videoSourceType VideoSourceType @default(UPLOAD)
  videoFilePath   String?
  youtubeUrl      String?
  vimeoUrl        String?
  externalUrl     String?
  durationMinutes Int             @default(0)
  progress        LessonProgress[]
}

model TrainingResource {
  id         String   @id @default(cuid())
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  trainingId String
  titleFr    String
  titleEn    String
  filePath   String
  order      Int      @default(0)
}

model TrainingFaqItem {
  id         String   @id @default(cuid())
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  trainingId String
  questionFr String
  questionEn String
  answerFr   String
  answerEn   String
  order      Int      @default(0)
}

model TrainingComment {
  id          String       @id @default(cuid())
  training    Training     @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  trainingId  String
  authorName  String
  authorEmail String
  comment     String
  status      ReviewStatus @default(PENDING)
  ipAddress   String       @default("")
  createdAt   DateTime     @default(now())
}

model LessonProgress {
  id            String         @id @default(cuid())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  lesson        TrainingLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId      String
  training      Training       @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  trainingId    String
  completed     Boolean        @default(false)
  completedAt   DateTime?
  lastWatchedAt DateTime       @default(now())

  @@unique([userId, lessonId])
}

model Certificate {
  id                String   @id @default(cuid())
  certificateNumber String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  training          Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  trainingId        String
  issuedAt          DateTime @default(now())

  @@unique([userId, trainingId])
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  passwordHash    String
  emailVerifiedAt DateTime?
  avatarPath      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sessions        UserSession[]
  tokens          UserToken[]
  lessonProgress  LessonProgress[]
  certificates    Certificate[]
}

model UserSession {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model UserToken {
  id         String        @id @default(cuid())
  token      String        @unique
  type       UserTokenType
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime      @default(now())
}

model SiteSetting {
  id                String   @id @default("singleton")
  palette           Palette  @default(RED_BLACK)
  reviewModeration  Boolean  @default(true)
  heroTaglinesFr    String   @default("")
  heroTaglinesEn    String   @default("")
  agencyIntroFr     String   @default("")
  agencyIntroEn     String   @default("")
  aboutTextFr       String   @default("")
  aboutTextEn       String   @default("")
  teamTextFr        String   @default("")
  teamTextEn        String   @default("")
  planetTextFr      String   @default("")
  planetTextEn      String   @default("")
  adSpaceTitleFr    String   @default("")
  adSpaceTitleEn    String   @default("")
  adSpaceTextFr     String   @default("")
  adSpaceTextEn     String   @default("")
  ctaTitleFr        String   @default("")
  ctaTitleEn        String   @default("")
  contactQuoteFr    String   @default("")
  contactQuoteEn    String   @default("")
  trustTitleFr      String   @default("")
  trustTitleEn      String   @default("")
  phone1            String   @default("")
  phone2            String   @default("")
  contactEmail      String   @default("")
  addressFr         String   @default("")
  addressEn         String   @default("")
  whatsappNumber    String   @default("")
  mapEmbedUrl       String   @default("")
  rccm              String   @default("")
  legalAddress      String   @default("")
  brochurePdfPath   String?
  logoLightPath     String?
  logoDarkPath      String?
  heroVideoPath     String?
  adSpaceMediaPath  String?
  adSpaceMediaType  String?
  whyUsImagePath    String?
  updatedAt         DateTime @updatedAt
}
